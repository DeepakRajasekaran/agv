<root BTCPP_format="4">
    <BehaviorTree ID="MainTree">
        <Sequence>
            <!-- Check if /navigation/start was triggered -->
            <Fallback>
                <Sequence>
                    <IsNavigationStarted is_started="{is_started}"/>
                    <SetLineFollowerState enable="true"/>
                </Sequence>
                <Sequence>
                    <SetLineFollowerState enable="false"/>
                </Sequence>
            </Fallback>
        </Sequence>
    </BehaviorTree>
</root>
