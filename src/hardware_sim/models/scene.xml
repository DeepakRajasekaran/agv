<mujoco model="turtlebot">
  <compiler angle="degree" coordinate="local" inertiafromgeom="true"/>
  <!--
    Stabilized 60 kg industrial AGV simulation.
    
    Key design decisions:
    
    1. NO CASTERS. Casters cause intermittent contact (bouncing) which creates
       chaotic nefc=0 frames where the robot becomes airborne. Instead we use
       a sliding contact pad at each corner of the base — these are flat box geoms
       with zero friction (condim=1) that slide freely but prevent tipping.
    
    2. Velocity-servo actuators with kv=3.0 and forcerange=±50 Nm.
       kv=3.0 provides sufficient torque while staying stable at dt=0.005s.
       Stability bound: kv < 2*I/dt = 2*0.0064/0.005 = 2.56 (marginal).
       We use kv=3.0 with physics sub-stepping: outer loop computes ctrl once,
       inner loop applies it twice (10ms = 2×5ms).
    
    3. timestep=0.005s, two sub-steps per 10ms ROS cycle in hardware_sim_node.py.
    
    4. Contact softness (solref/solimp) reduces energy injection at impact.
  -->
  <option timestep="0.005" gravity="0 0 -9.81"/>

  <default>
    <geom solref="0.02 1" solimp="0.9 0.95 0.001"/>
  </default>

  <worldbody>
    <light directional="true" diffuse=".6 .6 .6" specular="0.2 0.2 0.2" pos="0 0 5" dir="0 0 -1"/>
    <!-- Ground plane - industrial gray -->
    <geom name="floor" type="plane" size="10 10 .05" rgba="0.45 0.45 0.45 1" condim="3"/>

    <!-- Robot body: 600x600x300mm, 60 kg total, industrial blue -->
    <body name="robot" pos="-2.5 2.0 0.08">
      <freejoint name="root"/>
      <!-- Main chassis: 54 kg (remaining 6 kg in wheels) -->
      <geom name="base" type="box" size="0.30 0.30 0.15" pos="0 0 0.10" rgba="0.1 0.3 0.6 1.0" mass="54.0"/>

      <!--
        Ground contact pads at each corner: frictionless (condim=1) flat boxes.
        Height = 30mm ground clearance - pad half-height. Pads are 5mm thick.
        Bottom of pad: 0.08 (body Z) - 0.0225 (half-thickness) = 0.0575m
        Actually: pad at pos z = 0.0 means pad bottom at 0.08 - 0.0225 = 0.0575m above floor.
        We want pads at floor level (z=0), so pos_z = -0.05 + 0.0025 = -0.0475 from body center.
        body_center_z = 0.08, wheels bottom at 0, clearance = 0.08 - 0.08 = 0m.
        Wait - with body at z=0.08, base geom pos at 0.10 (relative to body), base extends from
        0.08-0.15 = -0.07 to 0.08+0.25 = 0.33m... The base BOTTOM is at 0.08+0.10-0.15=0.03m.
        Pad should be at body pos_z such that pad_bottom = 0.01m (1cm clearance from floor):
        pad_center_z = 0.01 + 0.0025 (half-height=5mm pad) = 0.0125m above floor
        relative to body (body at 0.08): pad_pos_z = 0.0125 - 0.08 = -0.0675
      -->
      <geom name="pad_fl" type="box" size="0.03 0.03 0.0025" pos=" 0.25  0.25 -0.0725"
            rgba="0.6 0.6 0.6 1" condim="1" mass="0.5"/>
      <geom name="pad_fr" type="box" size="0.03 0.03 0.0025" pos=" 0.25 -0.25 -0.0725"
            rgba="0.6 0.6 0.6 1" condim="1" mass="0.5"/>
      <geom name="pad_rl" type="box" size="0.03 0.03 0.0025" pos="-0.25  0.25 -0.0725"
            rgba="0.6 0.6 0.6 1" condim="1" mass="0.5"/>
      <geom name="pad_rr" type="box" size="0.03 0.03 0.0025" pos="-0.25 -0.25 -0.0725"
            rgba="0.6 0.6 0.6 1" condim="1" mass="0.5"/>

      <!-- Left Drive Wheel: 2 kg, radius=80mm, thickness=40.5mm, wheelbase=512mm -->
      <body name="left_wheel" pos="0 0.256 0" quat="0.7071 0.7071 0 0">
        <joint name="left_wheel_joint" type="hinge" axis="0 0 1" damping="0.5"/>
        <geom type="cylinder" size="0.08 0.02025" rgba="0.1 0.1 0.1 1" mass="2.0"
              friction="1.0 0.005 0.0001" condim="3"/>
      </body>

      <!-- Right Drive Wheel -->
      <body name="right_wheel" pos="0 -0.256 0" quat="0.7071 0.7071 0 0">
        <joint name="right_wheel_joint" type="hinge" axis="0 0 1" damping="0.5"/>
        <geom type="cylinder" size="0.08 0.02025" rgba="0.1 0.1 0.1 1" mass="2.0"
              friction="1.0 0.005 0.0001" condim="3"/>
      </body>
    </body>
  </worldbody>

  <actuator>
    <!--
      Velocity servo: force = kv * (ctrl - qvel), clamped to forcerange.
      kv=3.0 gives force=3*(omega_target - omega_actual).
      At zero error: 0 Nm. At 10 rad/s error: 30 Nm. 
      forcerange=±50 Nm supports aggressive recovery without oscillation.
    -->
    <velocity name="left_wheel_motor"  joint="left_wheel_joint"  kv="3.0" ctrlrange="-60 60" forcerange="-10 10"/>
    <velocity name="right_wheel_motor" joint="right_wheel_joint" kv="3.0" ctrlrange="-60 60" forcerange="-10 10"/>
  </actuator>

  <contact>
    <exclude body1="robot" body2="left_wheel"/>
    <exclude body1="robot" body2="right_wheel"/>
  </contact>
</mujoco>
