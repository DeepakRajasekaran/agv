<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="turtlebot">
  <xacro:arg name="mode" default="HARDWARE"/>
  <xacro:arg name="sim_tool" default="MUJOCO"/>

  <xacro:property name="wheel_radius" value="$(optenv WHEEL_RADIUS 0.08)"/>
  <xacro:property name="wheel_base" value="$(optenv WHEEL_BASE 0.512)"/>
  <xacro:property name="gear_ratio" value="$(optenv GEAR_RATIO 1.0)"/>
  <xacro:property name="ticks_per_rev" value="$(optenv TICKS_PER_REV 1024)"/>
  <xacro:property name="left_joint_name" value="$(optenv LEFT_JOINT_NAME left_wheel_joint)"/>
  <xacro:property name="right_joint_name" value="$(optenv RIGHT_JOINT_NAME right_wheel_joint)"/>
  <xacro:property name="feedback_topic" value="$(optenv FEEDBACK_TOPIC /drive/feedback)"/>
  <xacro:property name="cmd_topic" value="$(optenv CMD_TOPIC /cmd_rpm)"/>

  <!-- Minimal robot base link -->
  <link name="base_link"/>

  <!-- Left wheel joint -->
  <joint name="${left_joint_name}" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="left_wheel"/>

  <!-- Right wheel joint -->
  <joint name="${right_joint_name}" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="right_wheel"/>

  <!-- ros2_control integration -->
  <ros2_control name="RoboteqSystem" type="system">
    <hardware>
      <xacro:if value="${'$(arg mode)' == 'HARDWARE'}">
        <plugin>roboteq_driver/HardwareInterface</plugin>
        <param name="feedback_topic">${feedback_topic}</param>
        <param name="cmd_topic">${cmd_topic}</param>
      </xacro:if>

      <xacro:if value="${'$(arg mode)' == 'SIM'}">
        <xacro:if value="${'$(arg sim_tool)' == 'MUJOCO'}">
          <plugin>mujoco_ros2_control::MujocoRos2ControlPlugin</plugin>
        </xacro:if>
        <xacro:if value="${'$(arg sim_tool)' == 'GZ'}">
          <plugin>ign_ros2_control/IGNROS2ControlPlugin</plugin>
        </xacro:if>
      </xacro:if>

      <param name="wheel_radius">${wheel_radius}</param>
      <param name="wheel_base">${wheel_base}</param>
      <param name="gear_ratio">${gear_ratio}</param>
      <param name="ticks_per_rev">${ticks_per_rev}</param>
      <param name="left_joint_name">${left_joint_name}</param>
      <param name="right_joint_name">${right_joint_name}</param>
    </hardware>
    <joint name="${left_joint_name}">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="${right_joint_name}">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>
</robot>
